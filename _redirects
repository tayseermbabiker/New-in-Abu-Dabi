# ---------------------------------------------------------------------------
# Standard redirects
# ---------------------------------------------------------------------------

# Redirect common variations to canonical URLs
/home              /                    301
/index             /                    301
/index.php         /                    301
/index.html        /                    301

# Redirect old WordPress URLs
/wp-admin/*        /                    301
/wp-content/*      /                    301
/wp-includes/*     /                    301
/wordpress/*       /                    301

# Handle trailing slashes consistently
/privacy/          /privacy.html        301
/terms/            /terms.html          301

# API endpoints
/api/whats-new     /.netlify/functions/whats-new  200

# SPA fallback - serve index.html for any unmatched routes
/*                 /index.html          404
